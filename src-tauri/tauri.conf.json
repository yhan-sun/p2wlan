{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "p2wlan",
  "version": "0.1.14",
  "identifier": "com.yhansun.p2wlan",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:14327",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "p2wlan 控制台",
        "width": 960,
        "height": 640,
        "minWidth": 680,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
